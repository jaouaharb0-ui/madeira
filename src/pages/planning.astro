---
import BaseLayout from '../layouts/BaseLayout.astro'
import { orderedDays, dayLabels } from '../data/trip'

const base = import.meta.env.BASE_URL
---

<BaseLayout title="Planning" description="Notre planning jour par jour pour Madère.">

  <div class="page-hero">
    <div class="shell">
      <p class="eyebrow">25 juillet — 1er août 2026</p>
      <h1 class="page-title">Planning</h1>
      <p class="page-sub" id="planning-stats">Chargement…</p>
    </div>
  </div>

  <section class="planning-section">
    <div class="shell">

      <!-- 8 jours — squelette statique hydraté par Supabase -->
      {orderedDays.map(d => (
        <details class="day-block day-block--empty" id={`dblock-${d}`}>
          <summary class="day-summary">
            <div class="day-summary-left">
              <span class="day-number">J{dayLabels[d].dayNumber}</span>
              <div class="day-meta">
                <span class="day-short">{dayLabels[d].short}</span>
                <h2 class="day-long">{dayLabels[d].long}</h2>
              </div>
            </div>
            <div class="day-summary-right">
              <span class="day-count day-count--empty" id={`dcount-${d}`}>Libre</span>
              <span class="day-chevron" aria-hidden="true">›</span>
            </div>
          </summary>
          <div class="day-content" id={`dcontent-${d}`}></div>
        </details>
      ))}

      <!-- Non assignées -->
      <details class="day-block day-block--unassigned" id="dblock-unassigned" hidden>
        <summary class="day-summary">
          <div class="day-summary-left">
            <span class="day-number day-number--dot">?</span>
            <div class="day-meta">
              <span class="day-short">—</span>
              <h2 class="day-long">Non assignées</h2>
            </div>
          </div>
          <div class="day-summary-right">
            <span class="day-count" id="dcount-unassigned">—</span>
            <span class="day-chevron" aria-hidden="true">›</span>
          </div>
        </summary>
        <div class="day-content" id="dcontent-unassigned"></div>
      </details>

    </div>
  </section>

</BaseLayout>

<script>
  import { getAssignments, setDay, toggleDone, subscribeToChanges } from '../lib/assignments'
  import { activities } from '../data/activities'
  import { orderedDays, dayLabels } from '../data/trip'
  import type { Day } from '../data/trip'

  const base = import.meta.env.BASE_URL

  const typeLabels: Record<string, string> = {
    surf: 'Surf', rando: 'Randonnée', restaurant: 'Restaurant',
    viewpoint: 'Point de vue', swim: 'Baignade', other: 'Autre',
  }
  const typeIcons: Record<string, string> = {
    surf: '🏄', rando: '🥾', restaurant: '🍽',
    viewpoint: '🔭', swim: '🏊', other: '📍',
  }
  const typeColors: Record<string, string> = {
    surf: '#1E4A6B', rando: '#3B6B45', restaurant: '#E06B2C',
    viewpoint: '#7FA8BE', swim: '#3A7599', other: '#7A8A92',
  }

  // ── Templates HTML ──────────────────────────────────────────────────────────

  function dayPickerHtml(slug: string, currentDay: string | null) {
    const optionsHtml = orderedDays.map(d => `
      <button class="dp-option ${currentDay === d ? 'dp-opt--active' : ''}" data-day="${d}" data-label="${dayLabels[d].long}" type="button">
        <span class="dp-opt-short">${dayLabels[d].short}</span>
        <span class="dp-opt-date">${dayLabels[d].date.slice(8)}</span>
      </button>
    `).join('')
    return `
      <div class="day-picker pcard-dp" data-slug="${slug}">
        <button class="dp-trigger pdp-trigger" type="button">
          <span class="dp-text">${currentDay ? dayLabels[currentDay as Day].short : '+ Jour'}</span>
          <span class="dp-chevron">▾</span>
        </button>
        <div class="dp-dropdown" hidden>
          <div class="dp-grid">${optionsHtml}</div>
          <button class="dp-clear" type="button" style="${currentDay ? '' : 'display:none'}">✕ Retirer</button>
        </div>
      </div>
    `
  }

  function makePcard(a: typeof activities[0], done: boolean, day: string | null) {
    return `
      <div class="pcard ${done ? 'pcard--done' : ''}" data-slug="${a.slug}">
        <button class="pcheck" type="button" data-slug="${a.slug}" aria-pressed="${done}" aria-label="${done ? 'Marquer comme non fait' : 'Marquer comme fait'}">
          <svg width="12" height="10" viewBox="0 0 12 10" fill="none" aria-hidden="true">
            <polyline points="1,5 4.5,8.5 11,1" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <div class="pcard-photo">
          <img src="${a.photos[0]}" alt="${a.name}" loading="lazy" />
        </div>
        <div class="pcard-body">
          <p class="pcard-type" style="color:${typeColors[a.type]}">${typeIcons[a.type]} ${typeLabels[a.type]}</p>
          <h3 class="pcard-name">${a.name}</h3>
          ${a.duration ? `<p class="pcard-meta">⏱ ${a.duration}</p>` : ''}
        </div>
        ${dayPickerHtml(a.slug, day)}
        <a href="${base}activities/${a.slug}/" class="pcard-link" aria-label="Voir la fiche">→</a>
      </div>
    `
  }

  function dayCardsHtml(items: Array<{ a: typeof activities[0]; done: boolean; day: string | null }>) {
    return `<div class="day-cards">${items.map(({ a, done, day }) => makePcard(a, done, day)).join('')}</div>`
  }

  // ── Rendu ───────────────────────────────────────────────────────────────────

  function render(assignmentMap: Map<string, { day: string | null; done: boolean }>) {
    const byDay: Record<string, Array<{ a: typeof activities[0]; done: boolean; day: string | null }>> =
      Object.fromEntries(orderedDays.map(d => [d, []]))
    const unassigned: Array<{ a: typeof activities[0]; done: boolean; day: string | null }> = []

    for (const a of activities) {
      const assignment = assignmentMap.get(a.slug)
      const day  = assignment?.day ?? null
      const done = assignment?.done ?? false
      if (day && byDay[day]) {
        byDay[day].push({ a, done, day })
      } else {
        unassigned.push({ a, done, day: null })
      }
    }

    // Stats
    const totalAssigned = activities.length - unassigned.length
    const stats = document.getElementById('planning-stats')
    if (stats) {
      stats.textContent = totalAssigned === 0
        ? `Aucune activité placée. ${activities.length} encore à assigner.`
        : `${totalAssigned} activité${totalAssigned > 1 ? 's' : ''} placée${totalAssigned > 1 ? 's' : ''} sur 8 jours.${unassigned.length > 0 ? ` ${unassigned.length} encore à assigner.` : ' Planning complet ✓'}`
    }

    // Sections jour
    for (const d of orderedDays) {
      const items   = byDay[d]
      const content = document.getElementById(`dcontent-${d}`)
      const count   = document.getElementById(`dcount-${d}`)
      const block   = document.getElementById(`dblock-${d}`)
      if (!content || !count || !block) continue

      if (items.length === 0) {
        content.innerHTML = '<p class="day-free">Aucune activité prévue — journée libre.</p>'
        count.textContent = 'Libre'
        count.className   = 'day-count day-count--empty'
        block.removeAttribute('open')
        block.classList.add('day-block--empty')
      } else {
        content.innerHTML = dayCardsHtml(items)
        count.textContent = `${items.length} activité${items.length > 1 ? 's' : ''}`
        count.className   = 'day-count'
        block.setAttribute('open', '')
        block.classList.remove('day-block--empty')
      }
    }

    // Section non assignées
    const unassignedBlock   = document.getElementById('dblock-unassigned') as HTMLDetailsElement
    const unassignedContent = document.getElementById('dcontent-unassigned')
    const unassignedCount   = document.getElementById('dcount-unassigned')
    if (unassignedBlock && unassignedContent && unassignedCount) {
      if (unassigned.length === 0) {
        unassignedBlock.hidden = true
      } else {
        unassignedBlock.hidden = false
        unassignedBlock.open   = true
        unassignedContent.innerHTML = dayCardsHtml(unassigned)
        unassignedCount.textContent = `${unassigned.length} activité${unassigned.length > 1 ? 's' : ''}`
      }
    }
  }

  // ── Événements (délégation) ─────────────────────────────────────────────────

  const section = document.querySelector('.planning-section')!

  section.addEventListener('click', async e => {
    const target = e.target as HTMLElement

    // Checkbox
    const pcheck = target.closest<HTMLButtonElement>('.pcheck')
    if (pcheck) {
      e.stopPropagation()
      await toggleDone(pcheck.dataset.slug!)
      render(await getAssignments())
      return
    }

    // Trigger day picker
    const trigger = target.closest<HTMLButtonElement>('.dp-trigger')
    if (trigger) {
      e.stopPropagation()
      const picker   = trigger.closest<HTMLElement>('.day-picker')!
      const dropdown = picker.querySelector<HTMLElement>('.dp-dropdown')!
      const opening  = dropdown.hidden
      closeAll()
      if (opening) { dropdown.hidden = false; picker.classList.add('dp--open') }
      return
    }

    // Choisir un jour
    const opt = target.closest<HTMLButtonElement>('.dp-option')
    if (opt) {
      e.stopPropagation()
      const slug = opt.closest<HTMLElement>('.day-picker')!.dataset.slug!
      closeAll()
      await setDay(slug, opt.dataset.day as Day)
      render(await getAssignments())
      return
    }

    // Retirer le jour
    const clear = target.closest<HTMLButtonElement>('.dp-clear')
    if (clear) {
      e.stopPropagation()
      const slug = clear.closest<HTMLElement>('.day-picker')!.dataset.slug!
      closeAll()
      await setDay(slug, null)
      render(await getAssignments())
      return
    }
  })

  document.addEventListener('click', closeAll)

  function closeAll() {
    document.querySelectorAll<HTMLElement>('.dp-dropdown').forEach(d => { d.hidden = true })
    document.querySelectorAll<HTMLElement>('.day-picker').forEach(p => p.classList.remove('dp--open'))
  }

  // ── Init + realtime ─────────────────────────────────────────────────────────

  async function init() {
    const map = await getAssignments()
    render(map)
    subscribeToChanges(async () => render(await getAssignments()))
  }
  init()
</script>

<style is:global>
  /* ── Hero ─────────────────────────────────────────────────────────────────── */
  .page-hero {
    padding-top: 9rem;
    padding-bottom: 4rem;
    background: linear-gradient(180deg, var(--color-stone-deep) 0%, var(--color-stone) 100%);
    border-bottom: 1px solid var(--color-stone-deep);
  }

  .page-title {
    font-size: clamp(3rem, 7vw, 6rem);
    color: var(--color-basalt);
    line-height: 1;
    margin-block: 0.5rem 0.75rem;
  }

  .page-sub {
    color: var(--color-basalt-soft);
    max-width: 520px;
  }

  /* ── Section ──────────────────────────────────────────────────────────────── */
  .planning-section {
    padding-block: 3rem 6rem;
  }

  /* ── Bloc jour ────────────────────────────────────────────────────────────── */
  .day-block {
    border-bottom: 1px solid var(--color-stone-deep);
  }

  .day-block:first-of-type {
    border-top: 1px solid var(--color-stone-deep);
  }

  .day-summary { list-style: none; }
  .day-summary::-webkit-details-marker { display: none; }

  .day-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: 1.5rem;
    cursor: pointer;
    gap: 1rem;
    user-select: none;
    transition: background 0.15s;
    border-radius: 4px;
  }

  .day-summary:hover { background: var(--color-stone-card); }
  .day-block--empty .day-summary { opacity: 0.5; }

  .day-summary-left {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .day-number {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 300;
    color: var(--color-ocean);
    width: 2.5rem;
    text-align: center;
    flex-shrink: 0;
  }

  .day-number--dot { color: var(--color-basalt-faint); }

  .day-meta {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .day-short {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-basalt-faint);
  }

  .day-long {
    font-size: clamp(1.1rem, 2.5vw, 1.6rem);
    font-weight: 500;
    color: var(--color-basalt);
    line-height: 1;
  }

  .day-summary-right {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-shrink: 0;
  }

  .day-count {
    font-size: 12px;
    font-weight: 500;
    color: var(--color-basalt-faint);
    background: var(--color-stone-deep);
    padding: 0.2rem 0.75rem;
    border-radius: 100px;
  }

  .day-count--empty {
    background: transparent;
    font-style: italic;
  }

  .day-chevron {
    font-size: 1.25rem;
    color: var(--color-basalt-faint);
    transition: transform 0.25s ease;
    line-height: 1;
  }

  details[open] .day-chevron { transform: rotate(90deg); }

  /* ── Contenu ──────────────────────────────────────────────────────────────── */
  .day-content { padding-bottom: 1.5rem; }

  .day-free {
    font-size: 14px;
    color: var(--color-basalt-faint);
    font-style: italic;
    padding-left: 3.75rem;
    padding-bottom: 0.5rem;
  }

  /* ── Non assignées ────────────────────────────────────────────────────────── */
  .day-block--unassigned {
    margin-top: 2.5rem;
    border: 1.5px dashed var(--color-stone-deep);
    border-radius: 12px;
    padding-inline: 1rem;
  }

  /* ── Cards ────────────────────────────────────────────────────────────────── */
  .day-cards {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding-left: 3.75rem;
  }

  .pcard {
    display: grid;
    grid-template-columns: 36px 64px 1fr auto auto;
    align-items: center;
    gap: 0.85rem;
    background: var(--color-stone-card);
    border: 1px solid var(--color-stone-deep);
    border-radius: 12px;
    overflow: visible;
    transition: box-shadow 0.2s, opacity 0.2s;
  }

  .pcard:hover { box-shadow: 0 4px 16px rgba(22,26,29,.08); }

  .pcard--done {
    opacity: 0.6;
  }

  .pcard--done .pcard-name {
    text-decoration: line-through;
    color: var(--color-basalt-faint);
  }

  /* Checkbox */
  .pcheck {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 2px solid var(--color-stone-deep);
    background: transparent;
    cursor: pointer;
    transition: all 0.2s;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: transparent;
    margin-left: 0.5rem;
  }

  .pcheck:hover {
    border-color: #3B6B45;
    background: rgba(59,107,69,.08);
    color: rgba(59,107,69,.4);
  }

  .pcard--done .pcheck {
    background: #3B6B45;
    border-color: #3B6B45;
    color: white;
  }

  /* Photo */
  .pcard-photo {
    width: 64px;
    height: 64px;
    flex-shrink: 0;
    border-radius: 0;
  }

  .pcard-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Body */
  .pcard-body {
    padding-block: 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    min-width: 0;
  }

  .pcard-type {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .pcard-name {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 500;
    color: var(--color-basalt);
    line-height: 1.2;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    transition: color 0.2s, text-decoration 0.2s;
  }

  .pcard-meta {
    font-size: 11px;
    color: var(--color-basalt-faint);
  }

  /* Day picker inline */
  .pcard-dp {
    position: relative;
    flex-shrink: 0;
  }

  .pdp-trigger {
    padding: 0.3rem 0.65rem;
    border-radius: 100px;
    border: 1.5px solid var(--color-stone-deep);
    background: transparent;
    color: var(--color-basalt-soft);
    font-size: 11px;
    font-family: var(--font-body);
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.3rem;
    transition: all 0.2s;
    white-space: nowrap;
  }

  .pdp-trigger:hover {
    border-color: var(--color-ocean);
    color: var(--color-ocean);
  }

  .pcard-dp .dp-dropdown {
    position: absolute;
    bottom: calc(100% + 6px);
    right: 0;
    left: auto;
    background: var(--color-stone);
    border: 1px solid var(--color-stone-deep);
    border-radius: 12px;
    padding: 0.5rem;
    box-shadow: 0 -8px 24px rgba(22,26,29,.18);
    z-index: 50;
    width: 200px;
  }

  .dp-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.2rem;
    margin-bottom: 0.35rem;
  }

  .dp-option {
    padding: 0.3rem 0.15rem;
    border: 1px solid transparent;
    border-radius: 7px;
    background: transparent;
    color: var(--color-basalt-soft);
    font-size: 9.5px;
    font-family: var(--font-body);
    cursor: pointer;
    transition: all 0.15s;
    text-align: center;
    line-height: 1.4;
  }

  .dp-option:hover { background: var(--color-stone-deep); }

  .dp-opt--active {
    background: var(--color-ocean) !important;
    color: white !important;
    border-color: var(--color-ocean) !important;
  }

  .dp-opt-short { display: block; font-weight: 600; }
  .dp-opt-date  { display: block; opacity: 0.7; }

  .dp-clear {
    width: 100%;
    padding: 0.3rem;
    border: none;
    background: transparent;
    color: var(--color-basalt-faint);
    font-size: 10px;
    font-family: var(--font-body);
    cursor: pointer;
    text-align: center;
    border-top: 1px solid var(--color-stone-deep);
    padding-top: 0.4rem;
    transition: color 0.15s;
  }

  .dp-clear:hover { color: var(--color-paradise); }

  .dp-chevron {
    font-size: 10px;
    line-height: 1;
    transition: transform 0.2s;
  }

  .day-picker.dp--open .dp-chevron { transform: rotate(180deg); }

  /* Lien fiche */
  .pcard-link {
    padding-right: 1.25rem;
    color: var(--color-basalt-faint);
    font-size: 1rem;
    text-decoration: none;
    transition: color 0.2s, transform 0.2s;
    display: inline-block;
  }

  .pcard:hover .pcard-link {
    color: var(--color-ocean);
    transform: translateX(3px);
  }

  /* ── Responsive ───────────────────────────────────────────────────────────── */
  @media (max-width: 640px) {
    .day-cards { padding-left: 0; }
    .day-long  { font-size: 1.1rem; }
    .pcard { grid-template-columns: 36px 56px 1fr auto; }
    .pcard-link { display: none; }
    .pcard-photo { width: 56px; height: 56px; }
  }
</style>
