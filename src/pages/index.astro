---
import BaseLayout from '../layouts/BaseLayout.astro'
import { activities } from '../data/activities'
import { orderedDays, dayLabels } from '../data/trip'

const base = import.meta.env.BASE_URL

const typeLabels: Record<string, string> = {
  surf: 'Surf',
  rando: 'Randonnée',
  restaurant: 'Restaurant',
  viewpoint: 'Point de vue',
  swim: 'Baignade',
  other: 'Autre',
}

const typeIcons: Record<string, string> = {
  surf: '🏄',
  rando: '🥾',
  restaurant: '🍽',
  viewpoint: '🔭',
  swim: '🏊',
  other: '📍',
}

const typeColors: Record<string, string> = {
  surf: '#1E4A6B',
  rando: '#3B6B45',
  restaurant: '#E06B2C',
  viewpoint: '#7FA8BE',
  swim: '#3A7599',
  other: '#7A8A92',
}

const allTypes = [...new Set(activities.map(a => a.type))]
---

<BaseLayout title="Accueil">
  <!-- ── Hero ──────────────────────────────────────────────────────────────── -->
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-content shell">
      <p class="hero-eyebrow">25 juillet — 1er août 2026 · 8 jours</p>
      <h1 class="hero-title"><em>Madère</em></h1>
      <div class="hero-cta">
        <a href={`${base}planning/`} class="btn btn-primary">Voir le planning</a>
        <a href={`${base}map/`} class="btn btn-ghost btn-ghost--light">Explorer la carte</a>
      </div>
    </div>
    <div class="hero-scroll-hint" aria-hidden="true">
      <span>Défiler</span>
      <svg width="16" height="24" viewBox="0 0 16 24" fill="none">
        <rect x="6.5" y="1" width="3" height="3" rx="1.5" fill="currentColor"/>
        <line x1="8" y1="6" x2="8" y2="22" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        <polyline points="4,18 8,22 12,18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>
  </section>

  <!-- ── Activités ─────────────────────────────────────────────────────────── -->
  <section class="activities-home">
    <div class="shell">
      <div class="section-header">
        <h2 class="section-title">Activités</h2>
        <!-- Filtres -->
        <div class="filters" role="group" aria-label="Filtrer par type">
          <button class="filter-btn active" data-filter="all">Tout</button>
          {allTypes.map(type => (
            <button class="filter-btn" data-filter={type}>
              {typeIcons[type]} {typeLabels[type]}
            </button>
          ))}
        </div>
      </div>

      <p class="flip-hint" aria-hidden="true">Clique sur une carte pour en savoir plus</p>

      <!-- Mosaïque flip cards -->
      <div class="mosaic-grid" id="mosaic-grid">
        {activities.map((activity) => (
          <div
            class="flip-card"
            data-type={activity.type}
            tabindex="0"
            role="button"
            aria-label={`${activity.name} — cliquer pour les détails`}
          >
            <div class="flip-card-inner">
              <!-- RECTO -->
              <div class="flip-card-front" aria-hidden="false">
                <div class="fcc-photo">
                  <img
                    src={activity.photos[0]}
                    alt={activity.name}
                    loading="lazy"
                  />
                  <div class="fcc-photo-overlay"></div>
                  <span class="fcc-type-chip" style={`background: ${typeColors[activity.type] ?? '#7A8A92'}`}>
                    {typeIcons[activity.type]} {typeLabels[activity.type]}
                  </span>
                </div>
                <div class="fcc-body">
                  <h3 class="fcc-name">{activity.name}</h3>
                  {activity.duration && (
                    <p class="fcc-meta">⏱ {activity.duration}</p>
                  )}
                </div>
              </div>

              <!-- VERSO -->
              <div class="flip-card-back" aria-hidden="true">
                <div class="fcb-inner">
                  <p class="fcb-type" style={`color: ${typeColors[activity.type] ?? '#7A8A92'}`}>
                    {typeIcons[activity.type]} {typeLabels[activity.type]}
                  </p>
                  <h3 class="fcb-name">{activity.name}</h3>
                  <p class="fcb-desc">{activity.shortDescription}</p>
                  <div class="fcb-infos">
                    <!-- Day picker — hydraté par Supabase -->
                    <div class="day-picker" data-slug={activity.slug}>
                      <button class="dp-trigger" type="button" aria-label="Assigner un jour">
                        <span class="dp-text">Assigner un jour</span>
                        <span class="dp-chevron">▾</span>
                      </button>
                      <div class="dp-dropdown" hidden>
                        <div class="dp-grid">
                          {orderedDays.map(d => (
                            <button
                              class="dp-option"
                              data-day={d}
                              data-label={dayLabels[d].long}
                              type="button"
                            >
                              <span class="dp-opt-short">{dayLabels[d].short}</span>
                              <span class="dp-opt-date">{dayLabels[d].date.slice(8)}</span>
                            </button>
                          ))}
                        </div>
                        <button class="dp-clear" type="button">✕ Retirer le jour</button>
                      </div>
                    </div>
                    {activity.duration && (
                      <span class="fcb-info-item">⏱ {activity.duration}</span>
                    )}
                    {activity.difficulty && (
                      <span class={`fcb-diff diff-${activity.difficulty}`}>
                        {activity.difficulty === 'easy' ? 'Facile' : activity.difficulty === 'medium' ? 'Intermédiaire' : 'Difficile'}
                      </span>
                    )}
                  </div>
                  <a
                    href={`${base}activities/${activity.slug}/`}
                    class="fcb-link"
                  >
                    Voir la fiche complète →
                  </a>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <p class="no-results" id="no-results" hidden>Aucune activité dans cette catégorie.</p>

      <div class="activities-footer">
        <a href={`${base}activities/`} class="btn btn-ghost">Toutes les activités →</a>
      </div>
    </div>
  </section>

  <!-- ── Planning preview — agenda ────────────────────────────────────────── -->
  <section class="planning-preview">
    <div class="shell">
      <div class="section-header">
        <h2 class="section-title">Le programme</h2>
        <a href={`${base}planning/`} class="btn btn-ghost">Voir tout →</a>
      </div>
      <div class="agenda">
        {orderedDays.map(d => (
          <div class="agenda-col">
            <div class="agenda-head">
              <span class="agenda-jnum">J{dayLabels[d].dayNumber}</span>
              <span class="agenda-datestr">
                {dayLabels[d].short}<br />{dayLabels[d].date.slice(8)}
              </span>
            </div>
            <div class="agenda-body" id={`agenda-${d}`}>
              <span class="agenda-empty">—</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Map preview ────────────────────────────────────────────────────────── -->
  <section class="map-preview">
    <div class="shell map-preview-inner">
      <div class="map-preview-text">
        <h2 class="section-title">Tous les spots<br />sur la carte</h2>
        <p class="map-preview-desc">Chaque activité géolocalisée, filtrée par type, avec les infos clés au clic.</p>
        <a href={`${base}map/`} class="btn btn-primary">Ouvrir la carte</a>
      </div>
      <a href={`${base}map/`} class="map-preview-thumb" aria-label="Voir la carte interactive">
        <img
          src="https://images.unsplash.com/photo-1555881400-74d7acaacd8b?w=800&q=80"
          alt="Aperçu carte Madère"
          loading="lazy"
        />
        <div class="map-preview-overlay">
          <span>Explorer →</span>
        </div>
      </a>
    </div>
  </section>
</BaseLayout>

<script>
  // ── Filtres ───────────────────────────────────────────────────────────────
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn')
  const cards = document.querySelectorAll<HTMLElement>('.flip-card')
  const noResults = document.getElementById('no-results')

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => b.classList.remove('active'))
      btn.classList.add('active')
      const filter = btn.dataset.filter ?? 'all'
      let visible = 0
      cards.forEach(card => {
        const show = filter === 'all' || card.dataset.type === filter
        card.style.display = show ? '' : 'none'
        if (show) visible++
        if (!show && card.classList.contains('is-flipped')) {
          card.classList.remove('is-flipped')
        }
      })
      if (noResults) noResults.hidden = visible > 0
    })
  })

  // ── Flip cards ────────────────────────────────────────────────────────────
  cards.forEach(card => {
    const flip = () => card.classList.toggle('is-flipped')

    card.addEventListener('click', e => {
      const target = e.target as HTMLElement
      if (target.closest('a')) return
      if (target.closest('.day-picker')) return
      flip()
    })

    card.addEventListener('keydown', e => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault()
        flip()
      }
      if (e.key === 'Escape') card.classList.remove('is-flipped')
    })
  })

</script>

<script>
  // ── Agenda — hydratation depuis Supabase ───────────────────────────────────
  import { getAssignments, subscribeToChanges } from '../lib/assignments'
  import { activities } from '../data/activities'

  const bySlug = Object.fromEntries(activities.map(a => [a.slug, a]))

  function renderAgenda(assignmentMap: Map<string, { day: string | null; done: boolean }>) {
    const byDay: Record<string, typeof activities> = {}
    for (const [slug, a] of assignmentMap) {
      if (a.day) {
        if (!byDay[a.day]) byDay[a.day] = []
        const act = bySlug[slug]
        if (act) byDay[a.day].push(act)
      }
    }
    document.querySelectorAll<HTMLElement>('.agenda-body').forEach(el => {
      const day  = el.id.replace('agenda-', '')
      const acts = byDay[day] ?? []
      if (acts.length === 0) {
        el.innerHTML = '<span class="agenda-empty">—</span>'
      } else {
        el.innerHTML = acts.map(a =>
          `<span class="agenda-tag agenda-tag--${a.type}">${a.name}</span>`
        ).join('')
      }
    })
  }

  async function initAgenda() {
    const map = await getAssignments()
    renderAgenda(map)
    subscribeToChanges(() => getAssignments().then(renderAgenda))
  }
  initAgenda()
</script>

<script>
  // ── Day picker — Supabase realtime ────────────────────────────────────────
  import { getAssignments, setDay, subscribeToChanges } from '../lib/assignments'
  import type { Day } from '../data/trip'

  async function init() {
    const map = await getAssignments()
    for (const [slug, a] of map) applyDay(slug, a.day)
    subscribeToChanges(row => {
      applyDay(row.activity_slug, row.day)
      flash(row.activity_slug)
    })
  }
  init()

  document.querySelectorAll<HTMLElement>('.day-picker').forEach(picker => {
    const slug     = picker.dataset.slug!
    const trigger  = picker.querySelector<HTMLButtonElement>('.dp-trigger')!
    const dropdown = picker.querySelector<HTMLElement>('.dp-dropdown')!

    trigger.addEventListener('click', e => {
      e.stopPropagation()
      const opening = dropdown.hidden
      closeAll()
      if (opening) { dropdown.hidden = false; picker.classList.add('dp--open') }
    })

    picker.querySelectorAll<HTMLButtonElement>('.dp-option').forEach(opt => {
      opt.addEventListener('click', async e => {
        e.stopPropagation()
        closeAll()
        await setDay(slug, opt.dataset.day as Day)
        applyDay(slug, opt.dataset.day!)
      })
    })

    picker.querySelector('.dp-clear')?.addEventListener('click', async e => {
      e.stopPropagation()
      closeAll()
      await setDay(slug, null)
      applyDay(slug, null)
    })
  })

  document.addEventListener('click', closeAll)

  function closeAll() {
    document.querySelectorAll<HTMLElement>('.dp-dropdown').forEach(d => { d.hidden = true })
    document.querySelectorAll<HTMLElement>('.day-picker').forEach(p => p.classList.remove('dp--open'))
  }

  function applyDay(slug: string, day: string | null) {
    const picker = document.querySelector<HTMLElement>(`.day-picker[data-slug="${slug}"]`)
    if (!picker) return
    const text = picker.querySelector<HTMLElement>('.dp-text')!
    picker.querySelectorAll('.dp-option').forEach(o => o.classList.remove('dp-opt--active'))
    if (day) {
      const opt = picker.querySelector<HTMLButtonElement>(`.dp-option[data-day="${day}"]`)
      text.textContent = `📅 ${opt?.dataset.label ?? day}`
      opt?.classList.add('dp-opt--active')
      picker.classList.add('dp--assigned')
    } else {
      text.textContent = 'Assigner un jour'
      picker.classList.remove('dp--assigned')
    }
  }

  function flash(slug: string) {
    const picker = document.querySelector<HTMLElement>(`.day-picker[data-slug="${slug}"]`)
    if (!picker) return
    picker.classList.remove('dp-flash')
    void picker.offsetWidth
    picker.classList.add('dp-flash')
    setTimeout(() => picker.classList.remove('dp-flash'), 700)
  }
</script>

<style>
  /* ── Hero ──────────────────────────────────────────────────────────────── */
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: flex-end;
    padding-bottom: 6rem;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 65% 30%, rgba(22, 26, 29, 0) 30%, rgba(22, 26, 29, 0.4) 100%),
      linear-gradient(
        160deg,
        #0D2A3D 0%,
        #1E4A6B 30%,
        #3A7599 65%,
        #7FA8BE 85%,
        #B8C8D4 100%
      );
  }

  .hero-bg::after {
    content: '';
    position: absolute;
    top: 18%;
    left: 60%;
    width: 340px;
    height: 340px;
    background: radial-gradient(circle, rgba(224, 107, 44, 0.22) 0%, rgba(58, 117, 153, 0.1) 40%, transparent 70%);
    border-radius: 50%;
    transform: translate(-50%, -50%);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    padding-top: 8rem;
  }

  .hero-eyebrow {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(232, 228, 221, 0.65);
    margin-bottom: 0.75rem;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(96px, 17vw, 200px);
    font-weight: 400;
    letter-spacing: -0.04em;
    line-height: 0.9;
    color: var(--color-stone);
    margin-bottom: 2.5rem;
  }

  .hero-title em {
    font-style: italic;
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .btn-ghost--light {
    border-color: rgba(232, 228, 221, 0.35);
    color: var(--color-stone);
  }

  .btn-ghost--light:hover {
    border-color: var(--color-stone);
    background: rgba(232, 228, 221, 0.1);
    color: var(--color-stone);
  }

  .hero-scroll-hint {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    color: rgba(232, 228, 221, 0.45);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    animation: float 3s ease-in-out infinite;
  }

  @keyframes float {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(6px); }
  }

  /* ── Section header ─────────────────────────────────────────────────────── */
  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .section-title {
    font-size: clamp(2rem, 4vw, 3rem);
    color: var(--color-basalt);
  }

  .filters {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .flip-hint {
    font-size: 12px;
    color: var(--color-basalt-faint);
    font-style: italic;
    margin-bottom: 1.75rem;
  }

  /* ── Activités section ──────────────────────────────────────────────────── */
  .activities-home {
    padding-block: 5rem 4rem;
  }

  /* ── Mosaïque ───────────────────────────────────────────────────────────── */
  .mosaic-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.1rem;
  }

  .no-results {
    text-align: center;
    padding: 3rem;
    color: var(--color-basalt-faint);
    font-style: italic;
  }

  .activities-footer {
    display: flex;
    justify-content: center;
    margin-top: 2rem;
  }

  /* ── Flip card ──────────────────────────────────────────────────────────── */
  .flip-card {
    perspective: 1000px;
    cursor: pointer;
    height: 220px;
    outline: none;
  }

  .flip-card:focus-visible {
    border-radius: var(--radius-card);
    outline: 2px solid var(--color-ocean);
    outline-offset: 3px;
  }

  .flip-card-inner {
    position: relative;
    width: 100%;
    height: 100%;
    transform-style: preserve-3d;
    transition: transform 0.55s cubic-bezier(0.4, 0, 0.2, 1);
    border-radius: var(--radius-card);
  }

  .flip-card.is-flipped .flip-card-inner {
    transform: rotateY(180deg);
  }

  .flip-card-front,
  .flip-card-back {
    position: absolute;
    inset: 0;
    border-radius: var(--radius-card);
    overflow: hidden;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    box-shadow: var(--shadow-card);
  }

  .flip-card-back {
    transform: rotateY(180deg);
    background: transparent;
    overflow: visible;
  }

  .fcb-inner {
    background: var(--color-stone-card);
  }

  /* Recto */
  .fcc-photo {
    position: relative;
    height: 68%;
    overflow: hidden;
  }

  .fcc-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .flip-card:not(.is-flipped):hover .fcc-photo img {
    transform: scale(1.05);
  }

  .fcc-photo-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(22,26,29,0.45) 0%, transparent 55%);
  }

  .fcc-type-chip {
    position: absolute;
    top: 0.7rem;
    left: 0.7rem;
    color: white;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.06em;
    padding: 0.25rem 0.6rem;
    border-radius: 100px;
  }

  .fcc-body {
    background: var(--color-stone-card);
    padding: 0.65rem 0.85rem;
    height: 32%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.2rem;
  }

  .fcc-name {
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--color-basalt);
    line-height: 1.2;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .fcc-meta {
    font-size: 11px;
    color: var(--color-basalt-faint);
  }

  /* Verso */
  .fcb-inner {
    height: 100%;
    padding: 0.9rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    border: 1px solid var(--color-stone-deep);
    border-radius: var(--radius-card);
  }

  .fcb-type {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .fcb-name {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 500;
    color: var(--color-basalt);
    line-height: 1.15;
  }

  .fcb-desc {
    font-size: 11.5px;
    color: var(--color-basalt-soft);
    line-height: 1.5;
    flex: 1;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  .fcb-infos {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: auto;
  }

  .fcb-info-item {
    font-size: 11px;
    color: var(--color-basalt-faint);
  }

  /* ── Day picker ────────────────────────────────────────────────────────── */
  .day-picker {
    position: relative;
    width: 100%;
  }

  .dp-trigger {
    width: 100%;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.3rem 0.65rem;
    border-radius: 100px;
    border: 1.5px dashed var(--color-basalt-faint);
    background: transparent;
    color: var(--color-basalt-faint);
    font-size: 11px;
    font-family: var(--font-body);
    cursor: pointer;
    transition: all 0.2s;
    text-align: left;
  }

  .dp-trigger:hover {
    border-color: var(--color-ocean);
    color: var(--color-ocean);
  }

  .day-picker.dp--assigned .dp-trigger {
    border: 1.5px solid var(--color-ocean);
    background: rgba(30, 74, 107, 0.08);
    color: var(--color-ocean);
    font-weight: 500;
  }

  .dp-chevron {
    margin-left: auto;
    font-size: 10px;
    line-height: 1;
    transition: transform 0.2s;
  }

  .day-picker.dp--open .dp-chevron { transform: rotate(180deg); }

  .dp-dropdown {
    position: absolute;
    bottom: calc(100% + 6px);
    left: 0;
    right: 0;
    background: var(--color-stone);
    border: 1px solid var(--color-stone-deep);
    border-radius: 12px;
    padding: 0.5rem;
    box-shadow: 0 -8px 24px rgba(22, 26, 29, 0.18);
    z-index: 30;
  }

  .dp-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.2rem;
    margin-bottom: 0.35rem;
  }

  .dp-option {
    padding: 0.3rem 0.15rem;
    border: 1px solid transparent;
    border-radius: 7px;
    background: transparent;
    color: var(--color-basalt-soft);
    font-size: 9.5px;
    font-family: var(--font-body);
    cursor: pointer;
    transition: all 0.15s;
    text-align: center;
    line-height: 1.4;
  }

  .dp-option:hover {
    background: var(--color-stone-deep);
    border-color: var(--color-stone-deep);
  }

  .dp-opt--active {
    background: var(--color-ocean) !important;
    color: white !important;
    border-color: var(--color-ocean) !important;
  }

  .dp-opt-short { display: block; font-weight: 600; }
