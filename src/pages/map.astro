---
import BaseLayout from '../layouts/BaseLayout.astro'
import { activities } from '../data/activities'
import { orderedDays, dayLabels } from '../data/trip'
import { typeLabels, typeColors, typeIconPaths } from '../data/typeIcons'

const base = import.meta.env.BASE_URL

// Config carte dérivée de la source unique (libellé + couleur)
const typeConfig: Record<string, { label: string; color: string }> = Object.fromEntries(
  Object.keys(typeLabels).map(t => [t, { label: typeLabels[t], color: typeColors[t] }])
)

// Icônes Lucide (tracés inline) pour la légende et les pins
const legendIcons = typeIconPaths

const activitiesJson = JSON.stringify(activities.map(a => ({
  slug: a.slug,
  name: a.name,
  type: a.type,
  photo: a.photos[0],
  shortDescription: a.shortDescription,
  coordinates: a.coordinates,
})))

const typeConfigJson = JSON.stringify(typeConfig)
const legendIconsJson = JSON.stringify(legendIcons)
const baseUrl = base

// Mapping jour → {dayNumber, long} pour le script Leaflet
const dayLabelsJson = JSON.stringify(
  Object.fromEntries(orderedDays.map(d => [d, { dayNumber: dayLabels[d].dayNumber, long: dayLabels[d].long }]))
)
---

<BaseLayout title="Carte" description="Carte interactive de tous nos spots à Madère.">
  <div class="map-page">
    <div id="map" class="map-container"></div>
  </div>

  <div class="map-controls">

      <!-- Bouton d'ouverture du panneau de filtres -->
      <button
        class="filters-toggle"
        id="filters-toggle"
        aria-expanded="false"
        aria-controls="filters-panel"
      >
        <svg class="filters-toggle-icon" viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
          <path d="M3 5h18M6 12h12M10 19h4" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none" />
        </svg>
        Filtres
        <span class="filters-badge" id="filters-badge" hidden></span>
      </button>

      <!-- Panneau de filtres (ouvre au clic) -->
      <div class="filters-panel" id="filters-panel">

        <!-- Filtres par type -->
        <div class="map-filters" role="group" aria-label="Filtrer par type">
          <button class="map-filter-btn type-filter-btn active" data-type="all">Tout</button>
          {Object.entries(typeConfig).map(([type, cfg]) => (
            <button class="map-filter-btn type-filter-btn" data-type={type} style={`--dot: ${cfg.color}`}>
              <span class="mfb-dot"></span>
              {cfg.label}
            </button>
          ))}
        </div>

        <!-- Filtres par jour (populé dynamiquement — grisé si aucune activité ce jour-là) -->
        <div class="map-day-filters" id="day-filters" role="group" aria-label="Filtrer par jour">
          <button class="day-filter-btn active" data-day="all">Tous les jours</button>
          {orderedDays.map(d => (
            <button class="day-filter-btn" data-day={d} id={`dfbtn-${d}`}>
              J{dayLabels[d].dayNumber}
            </button>
          ))}
        </div>
      </div>
  </div>

  <!-- Légende types (toujours visible, en bas à gauche) -->
  <div class="map-legend">
    {Object.entries(typeConfig).map(([type, cfg]) => (
      <span class="legend-item">
        <span class="legend-icon" style={`background:${cfg.color}`}>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={legendIcons[type]} />
        </span>
        {cfg.label}
      </span>
    ))}
  </div>
</BaseLayout>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" is:inline></script>

<script define:vars={{ activitiesJson, typeConfigJson, legendIconsJson, baseUrl, dayLabelsJson }}>
  const activities  = JSON.parse(activitiesJson)
  const typeConfig  = JSON.parse(typeConfigJson)
  const legendIcons = JSON.parse(legendIconsJson)
  const dayLabels   = JSON.parse(dayLabelsJson)

  // Construit un SVG Lucide inline (blanc) pour un type donné
  function iconSvg(type, size = 16, color = 'white') {
    const paths = legendIcons[type] || ''
    return `<svg viewBox="0 0 24 24" fill="none" stroke="${color}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="${size}" height="${size}">${paths}</svg>`
  }

  // ── État des filtres ──────────────────────────────────────────────────────
  let activeType = 'all'
  let activeDay  = 'all'

  // Assignations chargées depuis Supabase via CustomEvent
  const assignmentsBySlug = {}

  // ── Init carte ────────────────────────────────────────────────────────────
  const map = L.map('map', { center: [32.7, -17.0], zoom: 10, zoomControl: false })
  L.control.zoom({ position: 'bottomright' }).addTo(map)
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
    maxZoom: 18,
  }).addTo(map)

  // ── Marker factory avec badge jour optionnel ──────────────────────────────
  function makeIcon(type, active = true, dayNumber = null) {
    const cfg     = typeConfig[type] || typeConfig.other
    const color   = cfg.color
    const opacity = active ? '1' : '0'
    const events  = active ? 'auto' : 'none'
    const badge   = dayNumber
      ? `<span style="position:absolute;top:-5px;right:-5px;min-width:16px;height:16px;background:white;border:1.5px solid ${color};border-radius:50%;font-size:8px;font-weight:700;color:${color};display:flex;align-items:center;justify-content:center;line-height:1;padding:0 2px">${dayNumber}</span>`
      : ''
    return L.divIcon({
      className: '',
      html: `
        <div style="position:relative;width:36px;height:36px;opacity:${opacity};pointer-events:${events};transition:opacity .2s">
          <div style="width:36px;height:36px;background:${color};border:3px solid #E8E4DD;border-radius:50% 50% 50% 4px;transform:rotate(-45deg);box-shadow:0 4px 16px rgba(22,26,29,.35)"></div>
          <span style="position:absolute;top:50%;left:50%;transform:translate(-50%,-58%);display:flex;line-height:0">${iconSvg(type)}</span>
          ${badge}
        </div>
      `,
      iconSize: [36, 36],
      iconAnchor: [18, 36],
      popupAnchor: [0, -38],
    })
  }

  // ── Markers + popups ──────────────────────────────────────────────────────
  const markersByType = {}
  const markersBySlug = {}

  activities.forEach(activity => {
    const cfg    = typeConfig[activity.type] || typeConfig.other
    const marker = L.marker(
      [activity.coordinates.lat, activity.coordinates.lng],
      { icon: makeIcon(activity.type) }
    )

    marker.bindPopup(L.popup({
      maxWidth: 300,
      className: 'custom-popup',
      closeButton: false,
    }).setContent(`
      <div class="popup-inner">
        <img class="popup-photo" src="${activity.photo}" alt="${activity.name}" width="88" height="88" />
        <div class="popup-body">
          <p class="popup-type">${iconSvg(activity.type, 12, cfg.color)} ${cfg.label}</p>
          <h3 class="popup-title">${activity.name}</h3>
          <span class="popup-day" id="popup-day-${activity.slug}"></span>
          <a href="${baseUrl}activities/${activity.slug}/" class="popup-link">Voir la fiche →</a>
        </div>
      </div>
    `))

    marker.addTo(map)
    markersBySlug[activity.slug] = marker
    if (!markersByType[activity.type]) markersByType[activity.type] = []
    markersByType[activity.type].push(marker)
  })

  // ── Application des filtres combinés ──────────────────────────────────────
  function applyFilters() {
    activities.forEach(activity => {
      const assignment = assignmentsBySlug[activity.slug]
      const dayKey     = assignment?.day ?? null
      const dayNumber  = dayKey ? (dayLabels[dayKey]?.dayNumber ?? null) : null

      const typeMatch = activeType === 'all' || activity.type === activeType
      const dayMatch  = activeDay  === 'all' || dayKey === activeDay
      const show      = typeMatch && dayMatch

      markersBySlug[activity.slug].setIcon(
        makeIcon(activity.type, show, show && dayNumber ? dayNumber : null)
      )
      if (!show) markersBySlug[activity.slug].closePopup()
    })
    updateFiltersBadge()
  }

  // ── Badge : nombre de filtres actifs sur le bouton ────────────────────────
  function updateFiltersBadge() {
    const count = (activeType !== 'all' ? 1 : 0) + (activeDay !== 'all' ? 1 : 0)
    const badge = document.getElementById('filters-badge')
    if (!badge) return
    if (count > 0) {
      badge.textContent = String(count)
      badge.hidden = false
    } else {
      badge.hidden = true
    }
  }

  // ── Ouverture / fermeture du panneau de filtres ───────────────────────────
  const mapControls = document.querySelector('.map-controls')
  const filtersToggle = document.getElementById('filters-toggle')
  filtersToggle.addEventListener('click', (e) => {
    e.stopPropagation()
    const open = mapControls.classList.toggle('open')
    filtersToggle.setAttribute('aria-expanded', open ? 'true' : 'false')
    if (open) map.closePopup()
  })
  document.addEventListener('click', (e) => {
    if (mapControls.classList.contains('open') && !mapControls.contains(e.target)) {
      mapControls.classList.remove('open')
      filtersToggle.setAttribute('aria-expanded', 'false')
    }
  })
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && mapControls.classList.contains('open')) {
      mapControls.classList.remove('open')
      filtersToggle.setAttribute('aria-expanded', 'false')
    }
  })

  // ── Filtres type ──────────────────────────────────────────────────────────
  document.querySelectorAll('.type-filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.type-filter-btn').forEach(b => b.classList.remove('active'))
      btn.classList.add('active')
      activeType = btn.dataset.type
      applyFilters()
    })
  })

  // ── Filtres jour ──────────────────────────────────────────────────────────
  document.querySelectorAll('.day-filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.day-filter-btn').forEach(b => b.classList.remove('active'))
      btn.classList.add('active')
      activeDay = btn.dataset.day
      applyFilters()
    })
  })

  // ── Écoute les assignations Supabase (module script) ─────────────────────
  window.addEventListener('assignments-ready', e => {
    for (const a of e.detail) {
      assignmentsBySlug[a.activity_slug] = a
      updatePopupDay(a.activity_slug, a.day)
    }
    // Met à jour les boutons jour : grisé si aucune activité ce jour-là
    updateDayFilterState()
    applyFilters()
  })

  window.addEventListener('assignment-updated', e => {
    const a = e.detail
    assignmentsBySlug[a.activity_slug] = a
    updatePopupDay(a.activity_slug, a.day)
    updateDayFilterState()
    applyFilters()
  })

  function updatePopupDay(slug, day) {
    const el = document.getElementById(`popup-day-${slug}`)
    if (el) el.textContent = day ? `📅 ${dayLabels[day]?.long ?? day}` : ''
  }

  function updateDayFilterState() {
    const assignedDays = new Set(
      Object.values(assignmentsBySlug).map(a => a.day).filter(Boolean)
    )
    document.querySelectorAll('.day-filter-btn[data-day]').forEach(btn => {
      const d = btn.dataset.day
      if (d !== 'all') {
        btn.classList.toggle('day-filter-btn--empty', !assignedDays.has(d))
      }
    })
  }
</script>

<!-- Module script Supabase : charge les assignations et abonne au realtime -->
<script>
  import { getAssignments, subscribeToChanges } from '../lib/assignments'

  async function init() {
    const map = await getAssignments()
    window.dispatchEvent(new CustomEvent('assignments-ready', { detail: [...map.values()] }))
    subscribeToChanges(row => {
      window.dispatchEvent(new CustomEvent('assignment-updated', { detail: row }))
    })
  }
  init()
</script>

<style>
  .map-page {
    position: fixed;
    inset: 0;
    z-index: 0;
  }

  .map-container {
    width: 100%;
    height: 100%;
  }

  /* ── Contrôles flottants ────────────────────────────────────────────── */
  .map-controls {
    position: fixed;
    top: 1rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 600;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    pointer-events: none;
  }

  /* ── Bouton d'ouverture ─────────────────────────────────────────────── */
  .filters-toggle {
    pointer-events: all;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.55rem 1.1rem;
    border: 1px solid rgba(216, 210, 200, 0.8);
    border-radius: 100px;
    background: rgba(232, 228, 221, 0.92);
    backdrop-filter: blur(12px);
    color: var(--color-basalt);
    font-family: inherit;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.02em;
    cursor: pointer;
    box-shadow: 0 8px 32px rgba(22,26,29,0.18);
    transition: background 0.2s, transform 0.2s;
  }

  .filters-toggle:hover { background: rgba(232, 228, 221, 1); }
  .map-controls.open .filters-toggle {
    background: var(--color-basalt);
    color: var(--color-stone);
  }

  .filters-toggle-icon { flex-shrink: 0; }

  .filters-badge {
    min-width: 18px;
    height: 18px;
    padding: 0 5px;
    border-radius: 100px;
    background: var(--color-paradise);
    color: white;
    font-size: 11px;
    font-weight: 700;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }

  /* ── Panneau de filtres (collapsible) ───────────────────────────────── */
  .filters-panel {
    pointer-events: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    max-width: 100%;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-8px);
    transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s;
  }

  .map-controls.open .filters-panel {
    pointer-events: all;
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .map-filters {
    display: flex;
    gap: 0.5rem;
    flex-wrap: nowrap;
    justify-content: center;
    max-width: 100%;
    pointer-events: all;
    background: rgba(232, 228, 221, 0.92);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(216, 210, 200, 0.8);
    border-radius: 100px;
    padding: 0.4rem;
    box-shadow: 0 8px 32px rgba(22,26,29,0.18);
  }

  .map-filter-btn {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 1rem;
    border-radius: 100px;
    border: none;
    background: transparent;
    color: var(--color-basalt-soft);
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
    white-space: nowrap;
  }

  .map-filter-btn.active {
    background: var(--color-basalt);
    color: var(--color-stone);
  }

  .mfb-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--dot, var(--color-basalt-faint));
    flex-shrink: 0;
  }

  /* ── Filtres jour ───────────────────────────────────────────────────── */
  .map-day-filters {
    display: flex;
    gap: 0.35rem;
    flex-wrap: wrap;
    justify-content: center;
    pointer-events: all;
    background: rgba(232, 228, 221, 0.88);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(216, 210, 200, 0.7);
    border-radius: 100px;
    padding: 0.35rem;
    box-shadow: 0 4px 16px rgba(22,26,29,0.12);
  }

  .day-filter-btn {
    padding: 0.3rem 0.75rem;
    border-radius: 100px;
    border: none;
    background: transparent;
    color: var(--color-basalt-soft);
    font-size: 12px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
    white-space: nowrap;
    letter-spacing: 0.02em;
  }

  .day-filter-btn.active {
    background: var(--color-ocean);
    color: white;
  }

  .day-filter-btn--empty {
    opacity: 0.4;
  }

  /* ── Légende ────────────────────────────────────────────────────────── */
  .map-legend {
    position: fixed;
    bottom: 1rem;
    left: 1rem;
    z-index: 600;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    background: rgba(232, 228, 221, 0.85);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(216, 210, 200, 0.7);
    border-radius: 16px;
    padding: 0.75rem 1rem;
    box-shadow: 0 4px 16px rgba(22,26,29,0.12);
    pointer-events: none;
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 11px;
    font-weight: 500;
    color: var(--color-basalt-soft);
    letter-spacing: 0.04em;
  }

  .legend-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    flex-shrink: 0;
    color: white;
    box-shadow: 0 1px 3px rgba(22,26,29,0.2);
  }

  .legend-icon svg {
    width: 13px;
    height: 13px;
  }

  /* ── Popup ──────────────────────────────────────────────────────────── */
  :global(.custom-popup .leaflet-popup-content-wrapper) {
    border-radius: 16px;
    padding: 0;
    overflow: hidden;
    box-shadow: 0 24px 60px rgba(22,26,29,0.35);
    border: 1px solid rgba(216,210,200,0.5);
  }

  :global(.custom-popup .leaflet-popup-content) {
    margin: 0;
    width: 300px !important;
  }

  :global(.custom-popup .leaflet-popup-tip-container) { display: none; }

  :global(.popup-inner) {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    display: flex;
    background: #EFEAE3;
  }

  :global(.popup-photo) {
    width: 88px;
    height: 88px;
    flex-shrink: 0;
    object-fit: cover;
    display: block;
  }

  :global(.popup-body) {
    flex: 1;
    padding: 0.75rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    min-width: 0;
  }

  :global(.popup-type) {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #7A8A92;
  }

  :global(.popup-type svg) {
    flex-shrink: 0;
  }

  :global(.popup-title) {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.05rem;
    font-weight: 500;
    color: #161A1D;
    line-height: 1.2;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  :global(.popup-day) {
    font-size: 11px;
    color: #1E4A6B;
    font-weight: 500;
    min-height: 0;
  }

  :global(.popup-link) {
    display: inline-block;
    font-size: 11px;
    font-weight: 600;
    color: #1E4A6B;
    letter-spacing: 0.03em;
    margin-top: auto;
    padding-top: 0.35rem;
    transition: color 0.2s;
  }

  :global(.popup-link:hover) { color: #E06B2C; }

  /* ── Responsive ─────────────────────────────────────────────────────── */
  @media (max-width: 640px) {
    .map-controls { top: 4.5rem; width: 100%; padding-inline: 1rem; }
    .map-filters  { border-radius: 16px; padding: 0.5rem; }
    .map-day-filters { border-radius: 16px; padding: 0.5rem; }
    .map-legend   { display: none; }
  }
</style>
